# Copia este archivo como ".env" y completa con tus datos reales.
# NUNCA subas el archivo ".env" ni la carpeta "wallet/" a un repositorio publico.

# Usuario y contraseña del esquema en Oracle Autonomous DB
DB_USER=ADMIN
DB_PASSWORD=Txnxrxo@0219

# Alias de conexion tal como aparece en wallet/tnsnames.ora
# (algo como midb_high, midb_medium o midb_low)
DB_DSN=lenguajesdb_high

# Ruta a la carpeta donde descomprimiste el wallet descargado de OCI
# (debe contener cwallet.sso, tnsnames.ora, ojdbc.properties, etc.)
WALLET_LOCATION=./wallet

# Password del wallet (el que pusiste al descargarlo desde OCI Console)
WALLET_PASSWORD=Txnxrxo@0219

# Clave secreta de Flask (para sesiones/flash messages)
FLASK_SECRET_KEY=lenguajesbd
